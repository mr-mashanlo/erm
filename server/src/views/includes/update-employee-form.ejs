<div class="modal-box">
  <h3 class="text-lg font-bold">Edit <%= employee.name %></h3>
  <form method="post" action="./<%= employee.id %>/update" class="mt-4">
    <div class="w-full">
      <label for="name" class="inline-block mb-1 font-bold">Name</label>
      <input id="name" name="name" type="text" value="<%= employee.name || '' %>" placeholder="Jane" class="w-full px-3 py-1.5 border border-zinc-200 bg-white rounded-md relative focus-visible:z-10" required />
    </div>
    <div class="mt-6">
      <button class="px-3 py-1.5 border border-zinc-200 bg-zinc-100 rounded-md cursor-pointer">Submit</button>
    </div>
  </form>
</div>