<!DOCTYPE html>

<html lang="en">

  <head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
    <title>Types</title>
    <meta name="title" content="@@title">
    <meta name="description" content="@@description">
    <meta property="og:type" content="website">
    <meta property="og:title" content="@@title">
    <meta property="og:description" content="@@description">
    <meta property="og:image" content="@@image">
    <meta property="og:url" content="@@url">
    <meta name="twitter:image" content="@@image">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="icon" href="/images/favicon.svg" sizes="32x32">
    <link rel="apple-touch-icon" href="/images/favicon.svg">
    <link rel="stylesheet" href="/css/main.css">
  </head>

  <body class="text-xs">
    <%- include('includes/header'); %>
    <section class="p-4 sm:p-10">
      <div class="border border-zinc-200 rounded-md">
        <div class="p-3 flex sm:items-center justify-between gap-3 flex-col sm:flex-row">
          <h3 class="text-sm font-black">Types</h3>
          <div class="w-full sm:w-auto flex items-center gap-3">
            <%- include('includes/search-form'); %>
            <button onclick="create_modal.showModal()" class="px-3 py-1.5 border border-zinc-200 bg-zinc-100 rounded-md cursor-pointer">Create</button>
            <dialog id="create_modal" class="modal">
              <%- include('includes/create-type-form'); %>
              <form method="dialog" class="modal-backdrop"><button>close</button></form>
            </dialog>
          </div> 
        </div>
        <div class="overflow-auto">
          <table class="w-full min-w-3xl text-left table-fixed">
            <thead>
              <tr class="border-t border-zinc-200">
                <th class="w-11 pl-3 py-4.5"></th>
                <th class="px-3 py-4.5">
                  <a href="<%= buildUrl({ sort: 'name', order: query.order === 'asc' ? 'desc' : 'asc' }) %>" class="inline-flex items-center gap-1 cursor-pointer">
                    <span>Name</span>
                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg>
                  </a>
                </th>
                <th class="px-3 py-4.5">
                  <a href="<%= buildUrl({ sort: 'types', order: query.order === 'asc' ? 'desc' : 'asc' }) %>" class="inline-flex items-center gap-1 cursor-pointer">
                    <span>Assets</span>
                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg>
                  </a>
                </th>
              </tr>
            </thead>
            <tbody>
              <% types.data.forEach( type => { %>
                <tr class="border-t border-zinc-200">
                  <td class="pl-3 py-3">
                    <button class="w-7.5 h-7.5 shrink-0 flex items-center justify-center text-center border border-none rounded-md cursor-pointer hover:bg-zinc-100" popovertarget="popover-<%= type.id %>" style="anchor-name:--anchor-<%= type.id %>">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg>
                    </button>
                    <ul id="popover-<%= type.id %>" class="dropdown w-52 mt-1 rounded-box bg-base-100 border border-zinc-200" popover style="position-anchor:--anchor-<%= type.id %>">
                      <li>
                        <button onclick="window['edit_modal_<%= type.id %>'].showModal()" class="w-full p-3 text-left cursor-pointer">Edit</button>
                        <dialog id="edit_modal_<%= type.id %>" class="modal">
                          <%- include('includes/update-type-form', { type }); %>
                          <form method="dialog" class="modal-backdrop"><button>close</button></form>
                        </dialog>
                      </li>
                      <li class="border-t border-zinc-200">
                        <button onclick="window['archive_modal_<%= type.id %>'].showModal()" class="w-full p-3 text-left text-red-500 cursor-pointer">Archive</button>
                        <dialog id="archive_modal_<%= type.id %>" class="modal">
                          <%- include('includes/archive-type-form', { type }); %>
                          <form method="dialog" class="modal-backdrop"><button>close</button></form>
                        </dialog>
                      </li>
                    </ul>
                  </td>
                  <td class="p-3"><%= type.name %></td>
                  <td class="p-3"><%= type.assets ? type.assets.length : 0 %> assets</td>
                </tr>
              <% } ); %>
            </tbody>
          </table>
        </div>
        <% if (types.total > types.limit) { %>
          <%- include('includes/pagination', { limit: types.limit, page: types.page, total: types.total }); %>
        <% } %>
      </div>
    </section>
  </body>

</html>